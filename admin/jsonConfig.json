{
    "type": "tabs",
    "items": {
        "tab_gateways": {
            "type": "tab",
            "label": "Шлюзы",
            "items": {
                "gateways": {
                    "type": "table",
                    "label": "Шлюзы RS485 / Modbus TCP",
                    "showSecondAddAt": 3,
                    "items": {
                        "name": {
                            "type": "text",
                            "label": "Название",
                            "default": "Gateway 1",
                            "width": "22%"
                        },
                        "host": {
                            "type": "text",
                            "label": "IP адрес",
                            "default": "192.168.1.95",
                            "width": "22%"
                        },
                        "port": {
                            "type": "number",
                            "label": "TCP порт",
                            "default": 23,
                            "min": 1,
                            "max": 65535,
                            "width": "12%"
                        },
                        "pollInterval": {
                            "type": "number",
                            "label": "Опрос (мс)",
                            "default": 10000,
                            "min": 1000,
                            "max": 60000,
                            "width": "15%"
                        },
                        "enabled": {
                            "type": "checkbox",
                            "label": "Активен",
                            "default": true,
                            "width": "8%"
                        }
                    }
                }
            }
        },
        "tab_devices": {
            "type": "tab",
            "label": "Устройства",
            "items": {
                "devices": {
                    "type": "table",
                    "label": "Modbus устройства",
                    "showSecondAddAt": 5,
                    "items": {
                        "name": {
                            "type": "text",
                            "label": "Название",
                            "default": "Device 1",
                            "width": "18%"
                        },
                        "gateway": {
                            "type": "text",
                            "label": "Шлюз",
                            "default": "Gateway 1",
                            "width": "18%"
                        },
                        "slaveId": {
                            "type": "number",
                            "label": "Slave ID",
                            "default": 1,
                            "min": 1,
                            "max": 247,
                            "width": "10%"
                        },
                        "deviceType": {
                            "type": "select",
                            "label": "Тип устройства",
                            "default": "WB-MAI6-since-fw-2.2",
                            "width": "32%",
                            "options": [
                                { "value": "WB-MAI6-since-fw-2.2", "label": "WB-MAI6 (аналоговые входы, fw ≥ 2.2)" },
                                { "value": "WB-MAP3E fw2",         "label": "WB-MAP3E (3-фазный счётчик, fw ≥ 2.0)" },
                                { "value": "WB-M1W2 MULTIPLE W1",  "label": "WB-M1W2 (1-Wire / счётные входы, fw ≥ 4.35)" },
                                { "value": "WB-MR6C",              "label": "WB-MR6C (реле 6 каналов)" },
                                { "value": "WB-MAP6S",             "label": "WB-MAP6S (счётчик 6 каналов)" },
                                { "value": "WB-MAP12E",            "label": "WB-MAP12E (счётчик 12 каналов)" },
                                { "value": "WB-MS",                "label": "WB-MS (датчик климата)" },
                                { "value": "WB-MDM3",              "label": "WB-MDM3 (диммер 3 канала)" },
                                { "value": "WB-MCM8",              "label": "WB-MCM8 (счётные входы 8 каналов)" },
                                { "value": "WB-MIO",               "label": "WB-MIO (универсальный ввод-вывод)" }
                            ]
                        },
                        "enabled": {
                            "type": "checkbox",
                            "label": "Активно",
                            "default": true,
                            "width": "8%"
                        }
                    }
                }
            }
        },
        "tab_options": {
            "type": "tab",
            "label": "Параметры",
            "items": {
                "pollInterval": {
                    "type": "number",
                    "label": "Интервал опроса по умолчанию (мс)",
                    "help": "Используется если не задан для конкретного шлюза",
                    "default": 10000,
                    "min": 1000,
                    "max": 60000
                },
                "requestTimeout": {
                    "type": "number",
                    "label": "Таймаут запроса Modbus (мс)",
                    "default": 3000,
                    "min": 500,
                    "max": 10000
                },
                "reconnectInterval": {
                    "type": "number",
                    "label": "Интервал переподключения (мс)",
                    "default": 5000,
                    "min": 1000,
                    "max": 60000
                }
            }
        }
    }
}
