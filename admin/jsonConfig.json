{
    "type": "tabs",
    "items": {
        "tab_gateways": {
            "type": "tab",
            "label": "Шлюзы",
            "items": {
                "gateways": {
                    "type": "table",
                    "label": "Шлюзы RS485 / Modbus TCP",
                    "showSecondAddAt": 3,
                    "items": [
                        { "attr": "name",         "type": "text",     "title": "Название",   "default": "Gateway 1",    "width": "22%" },
                        { "attr": "host",         "type": "text",     "title": "IP адрес",   "default": "192.168.1.95", "width": "22%" },
                        { "attr": "port",         "type": "number",   "title": "TCP порт",   "default": 23,             "width": "12%", "min": 1, "max": 65535 },
                        { "attr": "pollInterval", "type": "number",   "title": "Опрос (мс)", "default": 10000,          "width": "15%", "min": 1000 },
                        { "attr": "enabled",      "type": "checkbox", "title": "Активен",    "default": true,           "width": "8%" }
                    ]
                }
            }
        },
        "tab_devices": {
            "type": "tab",
            "label": "Устройства",
            "items": {
                "devices": {
                    "type": "table",
                    "label": "Modbus устройства",
                    "showSecondAddAt": 5,
                    "items": [
                        { "attr": "name",    "type": "text",   "title": "Название",  "default": "Device 1",  "width": "18%" },
                        { "attr": "gateway", "type": "text",   "title": "Шлюз",      "default": "Gateway 1", "width": "18%" },
                        { "attr": "slaveId", "type": "number", "title": "Slave ID",  "default": 1,           "width": "10%", "min": 1, "max": 247 },
                        {
                            "attr": "deviceType",
                            "type": "select",
                            "title": "Тип устройства",
                            "default": "WB-MAI6-since-fw-2.2",
                            "width": "32%",
                            "options": [
                                { "value": "WB-MAI6-since-fw-2.2", "label": "WB-MAI6 (аналоговые входы)" },
                                { "value": "WB-MAP3E fw2",         "label": "WB-MAP3E (3-фазный счётчик)" },
                                { "value": "WB-M1W2 MULTIPLE W1",  "label": "WB-M1W2 (1-Wire / счётные входы)" },
                                { "value": "WB-MR6C",              "label": "WB-MR6C (реле 6 каналов)" }
                            ]
                        },
                        { "attr": "enabled", "type": "checkbox", "title": "Активно", "default": true, "width": "8%" }
                    ]
                }
            }
        },
        "tab_options": {
            "type": "tab",
            "label": "Параметры",
            "items": {
                "pollInterval":      { "type": "number", "label": "Интервал опроса (мс)",         "default": 10000, "min": 1000, "max": 60000 },
                "requestTimeout":    { "type": "number", "label": "Таймаут Modbus (мс)",           "default": 3000,  "min": 500,  "max": 10000 },
                "reconnectInterval": { "type": "number", "label": "Интервал переподключения (мс)", "default": 5000,  "min": 1000, "max": 60000 }
            }
        }
    }
}